{
  "name": "zord-console",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "clean": "rm -rf .next node_modules/.cache",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f zord-console",
    "docker:recreate": "docker compose up --build --force-recreate -d",
    "docker:reset": "docker compose down --remove-orphans && npm run clean && docker compose up --build -d",
    "deploy": "npm run docker:build && npm run docker:up",
    "health": "curl -f http://localhost:3000/api/health"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "next": "14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "20.19.33",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "5.9.3"
  }
}
