# Jenkins Credentials Required (TEMPLATE)
# -------------------------------------------------------
# Do NOT store real secrets in git. Copy this file to
# `jenkins/credentials.local` and use it as your checklist.
# Create Jenkins credentials with the exact IDs below.
#
# Format:
# CREDENTIAL_ID=TYPE | DESCRIPTION

github-pat=Username/Password OR Secret text | GitHub token for repo checkout

aws-access-key-id=Secret text | AWS access key ID
aws-secret-access-key=Secret text | AWS secret access key

edge-db-user=Secret text | zord-edge DB username
edge-db-password=Secret text | zord-edge DB password
edge-db-name=Secret text | zord-edge DB name

intent-db-user=Secret text | zord-intent-engine DB username
intent-db-password=Secret text | zord-intent-engine DB password
intent-db-name=Secret text | zord-intent-engine DB name

relay-db-user=Secret text | zord-relay DB username
relay-db-password=Secret text | zord-relay DB password
relay-db-name=Secret text | zord-relay DB name

token-db-user=Secret text | zord-token-enclave DB username
token-db-password=Secret text | zord-token-enclave DB password
token-db-name=Secret text | zord-token-enclave DB name

token-enclave-master-key=Secret text | Base64 32-byte master key

zord-vault-key=Secret text | Zord vault key (intent engine)

gemini-api-key=Secret text | Single Gemini API key (optional)
gemini-api-keys=Secret text | Comma-separated Gemini API keys (preferred)

edge-signing-key=Secret file | ed25519 private key PEM file
