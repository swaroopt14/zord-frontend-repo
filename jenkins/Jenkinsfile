pipeline {
  agent any

  options {
    disableConcurrentBuilds()
    timestamps()
    // Disable the implicit "Declarative: Checkout SCM" so we can wipe the workspace first.
    skipDefaultCheckout(true)
  }

  parameters {
    string(name: 'BRANCH_NAME', defaultValue: 'main', description: 'Git branch to deploy')
    string(name: 'GIT_CREDENTIALS_ID', defaultValue: 'github-pat', description: 'Jenkins credential ID for cloning the private GitHub repo over HTTPS')
  }

  environment {
    GIT_URL = 'https://github.com/Arealis-network/Arealis-Zord.git'
    COMPOSE_FILE = 'docker-compose.ec2.yml'
    APP_ENV_FILE = 'backend/zord-intent-engine/.env'
    PROMPT_ENV_FILE = 'backend/zord-prompt-layer/.env'
    AWS_REGION = 'ap-south-1'
    CANONICAL_REGION = 'ap-southeast-2'
    EDGE_BUCKET = 'arealis-zord-vault'
    INTENT_BUCKET = 'canonical-worm-storage'
    AWS_EC2_METADATA_DISABLED = 'true'
  }

  stages {
    stage('Checkout') {
      steps {
        deleteDir()

        // Don't run raw `git` in a shell for private repos; it will prompt for creds and fail.
        // Use Jenkins-managed credentials for a non-interactive checkout of the requested branch.
        checkout([
          $class: 'GitSCM',
          branches: [[name: "*/${params.BRANCH_NAME}"]],
          userRemoteConfigs: [[url: env.GIT_URL, credentialsId: params.GIT_CREDENTIALS_ID]],
          extensions: [
            [$class: 'PruneStaleBranch'],
            [$class: 'WipeWorkspace']
          ]
        ])
      }
    }

    stage('Preflight') {
      steps {
        sh '''
          set -eux
          test -f "${COMPOSE_FILE}"
          docker --version
          docker compose version
        '''
      }
    }

    stage('Prepare Runtime Secrets') {
      steps {
        withCredentials([
          string(credentialsId: 'aws-access-key-id', variable: 'AWS_ACCESS_KEY_ID'),
          string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY'),
          // Create this in Jenkins as "Secret text" containing your Gemini API key.
          string(credentialsId: 'gemini-api-key', variable: 'GEMINI_API_KEY')
        ]) {
          sh '''
            set -eu
            cat > "${APP_ENV_FILE}" <<EOF
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_REGION=${AWS_REGION}
S3_BUCKET=${EDGE_BUCKET}
CANONICAL_AWS_REGION=${CANONICAL_REGION}
CANONICAL_S3_BUCKET=${INTENT_BUCKET}
AWS_EC2_METADATA_DISABLED=${AWS_EC2_METADATA_DISABLED}
EOF

            # Prompt-layer runtime env (used by docker-compose.ec2.yml env_file)
            cat > "${PROMPT_ENV_FILE}" <<EOF
SERVICE_NAME=zord-prompt-layer
HTTP_PORT=8086

GEMINI_API_KEY=${GEMINI_API_KEY}
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

EDGE_READ_DSN=postgres://zord_user:zord_password@zord-edge-postgres:5432/zord_edge_db?sslmode=disable
INTENT_READ_DSN=postgres://intent_user:intent_password@zord-intent-postgres:5432/zord_intent_engine_db?sslmode=disable
RELAY_READ_DSN=postgres://relay_user:relay_password@zord-relay-postgres:5432/zord_relay_db?sslmode=disable

CHROMA_URL=http://chroma:8000
CHROMA_COLLECTION=zord_prompt_chunks
DEFAULT_TOP_K=5
EOF
          '''
        }
      }
    }

    stage('Deploy') {
      steps {
        sh '''
          set -eux
          docker compose -f "${COMPOSE_FILE}" down --remove-orphans || true
          docker compose -f "${COMPOSE_FILE}" up -d --build
        '''
      }
    }

    stage('Post Deploy Check') {
      steps {
        sh '''
          set -eux
          docker compose -f "${COMPOSE_FILE}" ps
          curl -fsS http://127.0.0.1/api/health
        '''
      }
    }
  }

  post {
    always {
      sh '''
        docker compose -f "${COMPOSE_FILE}" ps || true
      '''
    }
    success {
      echo 'Deployment succeeded'
    }
    failure {
      echo 'Deployment failed'
    }
  }
}
